@model IEnumerable<PatientMS.Models.PatientReport>
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Patient Reports";

    string GetIcon(string fileName)
    {
        if (string.IsNullOrEmpty(fileName)) return "📎";
        var e = fileName.LastIndexOf('.');
        if (e < 0) return "📎";
        var ext = fileName.Substring(e).ToLower();
        if (ext == ".pdf") return "📄";
        if (ext == ".doc" || ext == ".docx") return "📝";
        if (ext == ".xls" || ext == ".xlsx") return "📊";
        if (ext == ".ppt" || ext == ".pptx") return "📋";
        if (ext == ".jpg" || ext == ".jpeg" || ext == ".png") return "🖼️";
        if (ext == ".txt") return "📃";
        if (ext == ".csv") return "📊";
        return "📎";
    }
}

<h1>Patient Reports</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Upload New Report</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Patient</th>
            <th>Title</th>
            <th>Description</th>
            <th>Files</th>
            <th>Upload Date</th>
            <th>Uploaded By</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Patient?.FullName</td>
                <td>@item.Title</td>
                <td>@item.Description</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.FilePath))
                    {
                        var paths = item.FilePath.Split(';');
                        var names = !string.IsNullOrEmpty(item.FileName)
                            ? item.FileName.Split(';')
                            : paths;

                        for (int i = 0; i < paths.Length; i++)
                        {
                            var path = paths[i].Trim();
                            var name = i < names.Length ? names[i].Trim() : "File " + (i + 1);
                            var icon = GetIcon(name);
                            <div>
                                <a href="@path" target="_blank" class="text-decoration-none">
                                    @icon @name
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        <span class="text-muted">No files</span>
                    }
                </td>
                <td>@item.UploadDate.ToString("dd MMM yyyy")</td>
                <td>@item.UploadedBy</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <text>
                            | <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                            | <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        </text>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>