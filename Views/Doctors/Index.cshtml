@model IEnumerable<PatientMS.Models.Doctor>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Doctors";
}

@section Styles {
    <style>
        .doctor-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            padding: 20px;
            border: 1px solid #f0f0f0;
            transition: box-shadow 0.2s;
            height: 100%;
        }

            .doctor-card:hover {
                box-shadow: 0 4px 24px rgba(0,0,0,0.13);
            }

        .doctor-avatar {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #e8f5e9;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            flex-shrink: 0;
        }

        .doctor-name {
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 2px;
            color: #1a202c;
        }

        .doctor-speciality {
            font-size: 0.82rem;
            color: #718096;
        }

        .doctor-info-row {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            font-size: 0.85rem;
            color: #4a5568;
            margin-bottom: 8px;
        }

            .doctor-info-row .icon {
                color: #48bb78;
                font-size: 1rem;
                margin-top: 2px;
            }

        .doctor-bio {
            font-size: 0.82rem;
            color: #718096;
            margin-bottom: 10px;
            line-height: 1.4;
        }

        .divider {
            border-top: 1px solid #f0f0f0;
            margin: 10px 0;
        }

        .badge-available {
            background: #c6f6d5;
            color: #276749;
            border-radius: 20px;
            padding: 2px 10px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .badge-unavailable {
            background: #fed7d7;
            color: #9b2c2c;
            border-radius: 20px;
            padding: 2px 10px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .btn-book {
            background: #38a169;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 8px 0;
            width: 100%;
            font-weight: 600;
            font-size: 0.95rem;
            transition: background 0.2s;
            text-decoration: none;
            display: block;
            text-align: center;
        }

            .btn-book:hover {
                background: #276749;
                color: #fff;
            }

        .btn-actions {
            display: flex;
            gap: 6px;
            margin-top: 8px;
        }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">Doctors</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success">+ Add New Doctor</a>
    }
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="doctor-card">

                @* Header *@
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="doctor-avatar">👤</div>
                    <div class="flex-grow-1">
                        <div class="doctor-name">@item.FullName</div>
                        <div class="doctor-speciality">@item.Specialisation</div>
                    </div>
                    <div>
                        @if (item.IsAvailable)
                        {
                            <span class="badge-available">Available</span>
                        }
                        else
                        {
                            <span class="badge-unavailable">Unavailable</span>
                        }
                    </div>
                </div>

                <div class="divider"></div>

                @* Available Time *@
                @if (item.Availabilities != null && item.Availabilities.Any(a => a.IsActive))
                {
                    <div class="doctor-info-row mt-2">
                        <span class="icon">📅</span>
                        <span>
                            <small class="text-muted">Available time</small><br />
                            @foreach (var av in item.Availabilities.Where(a => a.IsActive).Take(1))
                            {
                                @(av.StartTime.Hours.ToString("D2") + ":" + av.StartTime.Minutes.ToString("D2"))
                                <text> - </text>
                                @(av.EndTime.Hours.ToString("D2") + ":" + av.EndTime.Minutes.ToString("D2"))
                            }
                        </span>
                    </div>
                }

                @* Phone *@
                @if (!string.IsNullOrEmpty(item.PhoneNumber))
                {
                    <div class="doctor-info-row">
                        <span class="icon">📞</span>
                        <span>@item.PhoneNumber</span>
                    </div>
                }

                @* Email *@
                @if (!string.IsNullOrEmpty(item.Email))
                {
                    <div class="doctor-info-row">
                        <span class="icon">✉️</span>
                        <span>@item.Email</span>
                    </div>
                }

                @* Experience *@
                <div class="doctor-info-row">
                    <span class="icon">🏅</span>
                    <span>@item.YearsOfExperience years of experience</span>
                </div>

                @* Bio *@
                @if (!string.IsNullOrEmpty(item.Bio))
                {
                    <p class="doctor-bio mt-1">@item.Bio</p>
                }

                <div class="divider"></div>

                @* Actions *@
                <a asp-action="Details" asp-route-id="@item.Id" class="btn-book">
                    Details
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <div class="btn-actions">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-primary w-50">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-danger w-50">Delete</a>
                    </div>
                }

            </div>
        </div>
    }
</div>