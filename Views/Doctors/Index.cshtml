@model IEnumerable<PatientMS.Models.Doctor>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Doctors";
}

<h1>Doctors</h1>

<p>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">Add New Doctor</a>
    }
</p>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.FullName)</th>
            <th>@Html.DisplayNameFor(model => model.Specialisation)</th>
            <th>@Html.DisplayNameFor(model => model.PhoneNumber)</th>
            <th>@Html.DisplayNameFor(model => model.Email)</th>
            <th>@Html.DisplayNameFor(model => model.YearsOfExperience)</th>
            <th>@Html.DisplayNameFor(model => model.Bio)</th>
            <th>@Html.DisplayNameFor(model => model.IsAvailable)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.FullName)</td>
                <td>@Html.DisplayFor(modelItem => item.Specialisation)</td>
                <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                <td>@Html.DisplayFor(modelItem => item.YearsOfExperience)</td>
                <td>@Html.DisplayFor(modelItem => item.Bio)</td>
                <td>@Html.DisplayFor(modelItem => item.IsAvailable)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <text>
                            | <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                            | <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        </text>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>