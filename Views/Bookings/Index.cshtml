@model IEnumerable<PatientMS.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">Bookings</h1>
    <a asp-action="Create" class="btn btn-success">+ New Booking</a>
</div>

@* Doctor Cards Section *@
<h4 class="mb-3 text-muted">Available Doctors</h4>
<div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
    @foreach (var doctor in ViewBag.Doctors as IEnumerable<PatientMS.Models.Doctor> ?? Enumerable.Empty<PatientMS.Models.Doctor>())
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center me-3"
                             style="width:48px;height:48px;font-size:1.3rem;flex-shrink:0;">
                            👤
                        </div>
                        <div>
                            <h5 class="card-title mb-0 fw-bold">@doctor.FullName</h5>
                            <small class="text-muted">@doctor.Specialisation</small>
                        </div>
                    </div>

                    @if (doctor.Availabilities != null && doctor.Availabilities.Any())
                    {
                        <p class="mb-1">
                            <span class="text-success">🕐</span>
                            @foreach (var av in doctor.Availabilities.Where(a => a.IsActive).Take(1))
                            {
                                @($"{av.StartTime:hh\\:mm} AM - {av.EndTime:hh\\:mm} PM")
                            }
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(doctor.PhoneNumber))
                    {
                        <p class="mb-1 text-muted">
                            <small>📞 @doctor.PhoneNumber</small>
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(doctor.Bio))
                    {
                        <p class="mb-2 text-muted">
                            <small>@doctor.Bio</small>
                        </p>
                    }

                    <div class="mt-3">
                        <a asp-action="Create" asp-route-doctorId="@doctor.Id"
                           class="btn btn-success btn-sm w-100">
                            Book
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* Existing Bookings Table *@
<h4 class="mb-3 text-muted">All Bookings</h4>
<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Patient</th>
            <th>Doctor</th>
            <th>Appointment Date</th>
            <th>Appointment Time</th>
            <th>Status</th>
            <th>Reason for Visit</th>
            <th>Doctor Notes</th>
            <th>Created At</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Patient.FullName)</td>
                <td>@Html.DisplayFor(modelItem => item.Doctor.FullName)</td>
                <td>@Html.DisplayFor(modelItem => item.AppointmentDate)</td>
                <td>@Html.DisplayFor(modelItem => item.AppointmentTime)</td>
                <td>
                    <span class="badge @(item.Status == "Scheduled" ? "bg-success" : "bg-secondary")">
                        @item.Status
                    </span>
                </td>
                <td>@Html.DisplayFor(modelItem => item.ReasonForVisit)</td>
                <td>@Html.DisplayFor(modelItem => item.DoctorNotes)</td>
                <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}