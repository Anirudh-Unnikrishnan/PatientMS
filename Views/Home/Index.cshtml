@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h1 style="font-size:2rem;">
        Welcome, @(User.Identity?.Name ?? "Guest")
    </h1>
    <p style="color:#4a5568;">
        @DateTime.Now.ToString("dddd, dd MMMM yyyy") &nbsp;&middot;&nbsp;
        @DateTime.Now.ToString("HH:mm")
    </p>
</div>

<!-- Stats Cards -->
<div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
    gap:20px; margin-bottom:30px;">

    <div class="card text-center" style="border-top: 4px solid #4fd1c5;">
        <div style="font-size:2.8rem; font-weight:900; color:#4fd1c5;">
            @ViewData["PatientCount"]
        </div>
        <div style="color:#a0aec0; margin-top:4px; font-weight:600;">
            Total Patients
        </div>
    </div>

    <div class="card text-center" style="border-top: 4px solid #38a169;">
        <div style="font-size:2.8rem; font-weight:900; color:#38a169;">
            @ViewData["DoctorCount"]
        </div>
        <div style="color:#a0aec0; margin-top:4px; font-weight:600;">
            Total Doctors
        </div>
    </div>

    <div class="card text-center" style="border-top: 4px solid #d69e2e;">
        <div style="font-size:2.8rem; font-weight:900; color:#d69e2e;">
            @ViewData["TodayBookings"]
        </div>
        <div style="color:#a0aec0; margin-top:4px; font-weight:600;">
            Today's Bookings
        </div>
    </div>

    <div class="card text-center" style="border-top: 4px solid #9f7aea;">
        <div style="font-size:2.8rem; font-weight:900; color:#9f7aea;">
            @ViewData["PendingReports"]
        </div>
        <div style="color:#a0aec0; margin-top:4px; font-weight:600;">
            Patient Reports
        </div>
    </div>

</div>

<!-- Quick Actions + System Info -->
<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">

    <div class="card">
        <h4>Quick Actions</h4>
        <div style="display:flex; flex-direction:column; gap:12px; margin-top:16px;">
            <a asp-controller="Patients" asp-action="Create" class="btn btn-primary">
                Register New Patient
            </a>
            <a asp-controller="Bookings" asp-action="Create" class="btn btn-secondary">
                Book Appointment
            </a>
            <a asp-controller="Calendar" asp-action="Index" class="btn btn-secondary">
                View Calendar
            </a>
            @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
            {
                <a asp-controller="PatientReports" asp-action="Create"
                   class="btn btn-secondary">
                    Upload Report
                </a>
            }
        </div>
    </div>

    <div class="card">
        <h4>System Info</h4>
        <div style="margin-top:16px; display:flex; flex-direction:column; gap:12px;">

            <div style="background:#0f1117; border-radius:10px; padding:12px 16px;
                border:1px solid #2d3748;">
                <div style="color:#4a5568; font-size:0.75rem; font-weight:700;
                    text-transform:uppercase; letter-spacing:0.8px;">
                    Logged In As
                </div>
                <div style="color:#4fd1c5; font-weight:700; margin-top:6px; font-size:1rem;">
                    @(User.Identity?.Name ?? "Guest")
                </div>
            </div>

            <div style="background:#0f1117; border-radius:10px; padding:12px 16px;
                border:1px solid #2d3748;">
                <div style="color:#4a5568; font-size:0.75rem; font-weight:700;
                    text-transform:uppercase; letter-spacing:0.8px;">
                    Role
                </div>
                <div style="color:#4fd1c5; font-weight:700; margin-top:6px; font-size:1rem;">
                    @if (User.IsInRole("Admin"))
                    {
                        <span>Admin</span>
                    }
                    else if (User.IsInRole("Doctor"))
                    {
                        <span>Doctor</span>
                    }
                    else if (User.IsInRole("Receptionist"))
                    {
                        <span>Receptionist</span>
                    }
                    else
                    {
                        <span>User</span>
                    }
                </div>
            </div>

            <div style="background:#0f1117; border-radius:10px; padding:12px 16px;
                border:1px solid #2d3748;">
                <div style="color:#4a5568; font-size:0.75rem; font-weight:700;
                    text-transform:uppercase; letter-spacing:0.8px;">
                    Date
                </div>
                <div style="color:#4fd1c5; font-weight:700; margin-top:6px; font-size:1rem;">
                    @DateTime.Now.ToString("dddd, dd MMM yyyy")
                </div>
            </div>

            <div style="background:#0f1117; border-radius:10px; padding:12px 16px;
                border:1px solid #2d3748;">
                <div style="color:#4a5568; font-size:0.75rem; font-weight:700;
                    text-transform:uppercase; letter-spacing:0.8px;">
                    Time
                </div>
                <div style="color:#4fd1c5; font-weight:700; margin-top:6px; font-size:1rem;">
                    @DateTime.Now.ToString("HH:mm")
                </div>
            </div>

        </div>
    </div>

</div>